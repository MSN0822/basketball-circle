# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# scripts/apply-migration.mjs でDBへSQLを直接適用する場合のみ使用
SUPABASE_DB_URL=postgresql://user:password@host:5432/postgres

# 管理者認証
ADMIN_PASSWORD=your-admin-password
# 管理者セッション Cookie の署名鍵。ADMIN_PASSWORD とは別の長いランダム文字列を必ず設定。
ADMIN_SESSION_SECRET=your-random-admin-session-secret

# Google Maps（場所入力の候補表示に使用。未設定でもアプリはフォールバック動作）
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Vercel Cron（未設定だと自動削除が動きません）
# Vercel Dashboard > Settings > Environment Variables に設定してください。
CRON_SECRET=your-random-cron-secret

# QA / E2E（必要なときだけ設定）
QA_AUTH_EMAIL=qa@example.com
QA_AUTH_PASSWORD=your-qa-password
